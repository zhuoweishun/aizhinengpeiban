/**
 * 聊天页面样式
 * @description 统一 UI 规范
 */

@import '../../styles/variables/_index.scss';

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: $bg-secondary;
}

/* ========== 聊天头部 ========== */
.chat-header {
  background: $primary-gradient;
  padding: $padding-sm $page-padding;
  box-shadow: $shadow-primary-md;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.ai-info {
  display: flex;
  align-items: center;
  gap: $gap-md;
}

.ai-avatar {
  font-size: 48rpx;
}

.ai-detail {
  display: flex;
  flex-direction: column;
}

.ai-name {
  font-size: $font-size-lg;
  font-weight: $font-weight-bold;
  color: $text-white;
}

.ai-status {
  font-size: $font-size-xs;
  color: rgba($text-white, 0.9);
  margin-top: 4rpx;
}

.header-actions {
  display: flex;
  align-items: center;
}

.header-actions .action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: $radius-full;
  background: rgba($text-white, 0.2);
  transition: all $transition-fast;
}

.header-actions .action-btn:active {
  background: rgba($text-white, 0.4);
  transform: scale(0.9);
}

.header-actions .action-icon {
  font-size: $font-size-md;
}

/* ========== 消息列表 ========== */
.message-list {
  flex: 1;
  padding: $padding-xl $padding-md;
  padding-bottom: $padding-md;
}

.message-item {
  display: flex;
  align-items: flex-start;
  gap: $gap-md;
  margin-bottom: $margin-md;

  &.user-message {
    flex-direction: row-reverse;

    .message-content {
      background: $primary-gradient;

      .message-text {
        color: $text-white;
      }
    }

    .message-time {
      text-align: right;
      color: $text-muted;
    }
  }

  &.bot-message {
    .message-content {
      background: $bg-primary;

      .message-text {
        color: $text-primary;
      }
    }
  }
}

.message-avatar {
  font-size: 48rpx;
  flex-shrink: 0;
}

.message-content {
  max-width: 70%;
  padding: $padding-sm $padding-md;
  border-radius: $radius-lg;
  box-shadow: $shadow-sm;
}

.message-text {
  display: block;
  font-size: $font-size-md;
  line-height: $line-height-normal;
  word-wrap: break-word;
}

.message-time {
  display: block;
  font-size: $font-size-xs;
  color: $text-muted;
  margin-top: 8rpx;
}

/* ========== 错误消息 ========== */
.error-message {
  .message-avatar {
    font-size: 48rpx;
  }

  .error-content {
    background: $bg-error;
    border: 1rpx solid $border-error;
  }

  .error-text {
    color: $error-color;
    font-size: $font-size-sm;
  }

  .error-actions {
    margin-top: $margin-sm;
  }

  .retry-btn {
    display: inline-block;
    background: $primary-gradient;
    color: $text-white;
    font-size: $font-size-xs;
    padding: 8rpx 20rpx;
    border-radius: $radius-md;
    box-shadow: $shadow-primary-sm;
  }

  .retry-btn:active {
    opacity: 0.8;
    transform: scale(0.95);
  }
}

/* ========== 加载中 ========== */
.loading-message {
  display: flex;
  justify-content: center;
  padding: $padding-sm;
}

.loading-dots {
  display: flex;
  gap: $gap-sm;
  background: $bg-primary;
  padding: $padding-xs $padding-md;
  border-radius: $radius-lg;
  box-shadow: $shadow-sm;
}

.dot {
  font-size: 32rpx;
  color: $text-muted;
  animation: bounce 1.4s $ease-in-out infinite;

  &:nth-child(1) { animation-delay: 0s; }
  &:nth-child(2) { animation-delay: 0.2s; }
  &:nth-child(3) { animation-delay: 0.4s; }
}

/* ========== 快捷心情 ========== */
.quick-moods {
  display: flex;
  gap: $gap-md;
  padding: $padding-md $padding-md;
  background: $bg-primary;
  border-top: 1rpx solid $border-light;
}

.mood-item {
  flex: 1;
  text-align: center;
  padding: $padding-sm;
  background: $bg-secondary;
  border-radius: $radius-lg;
  font-size: $font-size-sm;
  color: $text-secondary;
  transition: all $transition-fast;

  &:active {
    background: $primary-color;
    color: $text-white;
    transform: scale(0.95);
  }
}

/* ========== 输入区域 ========== */
.input-bar {
  background: $bg-primary;
  padding: $padding-sm $padding-md;
  border-top: 1rpx solid $border-light;
  padding-bottom: calc($padding-sm + env(safe-area-inset-bottom));
}

.input-wrapper {
  display: flex;
  align-items: center;
  gap: $gap-md;
  background: $bg-secondary;
  border-radius: $radius-xxl;
  padding: $padding-xs $padding-sm;
}

.message-input {
  flex: 1;
  font-size: $font-size-md;
  padding: 8rpx 0;
  max-height: 120rpx;
}

.input-placeholder {
  color: $text-muted;
}

.action-buttons {
  display: flex;
  gap: $gap-sm;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: $radius-full;
  background: $bg-primary;
  box-shadow: $shadow-sm;
}

.btn-icon {
  font-size: $font-size-lg;
}

.send-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: $radius-full;
  background: $primary-gradient;
  box-shadow: $shadow-primary-sm;
}

.send-icon {
  font-size: $font-size-md;
  color: $text-white;
}
