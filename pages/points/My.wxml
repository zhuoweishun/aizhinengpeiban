<!--
  我的积分页面
  @description 查看积分明细
-->

<view class="container">

  <!-- 头部统计 -->
  <view class="header">
    <view class="points-summary">
      <view class="point-item">
        <text class="point-value">{{starlightPoints}}</text>
        <text class="point-label">星光值</text>
      </view>
      <view class="point-divider"></view>
      <view class="point-item">
        <text class="point-value">{{crystalDiamonds}}</text>
        <text class="point-label">晶钻</text>
      </view>
    </view>
  </view>

  <!-- 积分明细 -->
  <view class="records-section">
    <text class="section-title">📝 积分明细</text>

    <view class="records-list">
      <block wx:for="{{records}}" wx:key="id">
        <view class="record-item">
          <view class="record-icon">{{item.icon}}</view>
          <view class="record-info">
            <text class="record-title">{{item.title}}</text>
            <text class="record-time">{{item.createdAt}}</text>
          </view>
          <view class="record-amount {{item.amount > 0 ? 'positive' : 'negative'}}">
            <text class="amount-sign">{{item.amount > 0 ? '+' : ''}}</text>
            <text class="amount-value">{{item.amount}}</text>
          </view>
        </view>
      </block>
    </view>

    <view class="empty-state" wx:if="{{records.length === 0}}">
      <text class="empty-icon">📋</text>
      <text class="empty-text">暂无记录</text>
    </view>
  </view>

</view>
