<!--
  积分商城页面
  @description 使用积分兑换商品
-->

<view class="container">

  <!-- 头部统计 -->
  <view class="header">
    <view class="points-summary">
      <view class="point-item">
        <text class="point-value">{{starlightPoints}}</text>
        <text class="point-label">星光值</text>
      </view>
      <view class="point-divider"></view>
      <view class="point-item">
        <text class="point-value">{{crystalDiamonds}}</text>
        <text class="point-label">晶钻</text>
      </view>
    </view>
  </view>

  <!-- 商品列表 -->
  <view class="product-list">
    <block wx:for="{{products}}" wx:key="id">
      <view class="product-item">
        <view class="product-image">
          <text class="product-icon">{{item.icon}}</text>
        </view>
        <view class="product-info">
          <text class="product-name">{{item.name}}</text>
          <text class="product-desc">{{item.description}}</text>
          <view class="product-price">
            <text class="price-label">积分：</text>
            <text class="price-value">{{item.price}}</text>
          </view>
        </view>
        <button class="exchange-btn" bindtap="exchange" data-id="{{item.id}}">
          兑换
        </button>
      </view>
    </block>
  </view>

</view>
