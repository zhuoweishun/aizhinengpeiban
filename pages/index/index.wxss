/**
 * 首页样式
 * @description 主菜单页面样式 - 统一 UI 规范
 */

@import '../../styles/variables/_index.scss';

.container {
  min-height: 100vh;
  background: $bg-page;
  padding: 0 0 60rpx;
}

/* ========== 顶部状态栏 ========== */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: $padding-md $page-padding $padding-sm;
}

.date-time {
  display: flex;
  flex-direction: column;
}

.date {
  font-size: $font-size-sm;
  color: $text-secondary;
  font-weight: $font-weight-medium;
}

.time {
  font-size: $font-size-xs;
  color: $text-muted;
  margin-top: 4rpx;
}

.user-info {
  background: $primary-gradient;
  padding: 8rpx 20rpx;
  border-radius: $radius-lg;
}

.level {
  font-size: $font-size-sm;
  color: $text-white;
  font-weight: $font-weight-bold;
}

/* ========== 标题区域 ========== */
.header {
  text-align: center;
  padding: $padding-sm 0 $padding-md;
}

.main-title {
  display: block;
  font-size: $font-size-title;
  font-weight: $font-weight-bold;
  color: $text-primary;
  margin-bottom: 8rpx;
}

.sub-title {
  display: block;
  font-size: $font-size-sm;
  color: $text-muted;
}

/* ========== 树洞互动区域 ========== */
.tree-hole-section {
  background: rgba($bg-primary, 0.8);
  margin: $margin-md $page-padding;
  border-radius: $radius-xxl;
  padding: $padding-xl;
  box-shadow: $shadow-primary-md;
}

.tree-hole-image {
  text-align: center;
  margin-bottom: $margin-md;
}

.tree-hole-illustration {
  width: 240rpx;
  height: 240rpx;
}

.interaction-buttons {
  display: flex;
  justify-content: center;
  gap: $gap-lg;
}

.interaction-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: $gap-sm;
  background: $bg-primary;
  border-radius: $radius-lg;
  padding: $padding-sm $padding-md;
  box-shadow: $shadow-primary-sm;
  transition: all $transition-fast;
  min-width: 140rpx;

  &:active {
    transform: scale(0.9);
    box-shadow: $shadow-primary-xs;
  }
}

.btn-icon {
  font-size: 40rpx;
}

.btn-text {
  font-size: $font-size-xs;
  color: $text-secondary;
}

/* ========== Section 通用样式 ========== */
.section {
  margin: $margin-lg $page-padding $margin-md;
}

.section-title {
  margin-bottom: $margin-md;
}

.title {
  display: block;
  font-size: $font-size-lg;
  font-weight: $font-weight-bold;
  color: $text-primary;
  margin-bottom: 4rpx;
}

.hint {
  display: block;
  font-size: $font-size-xs;
  color: $text-muted;
}

/* ========== Grid 菜单 ========== */
.grid-menu {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: $gap-sm;
}

.grid-item {
  background: $bg-primary;
  border-radius: $radius-lg;
  padding: $padding-xl $padding-md;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: $gap-sm;
  box-shadow: $shadow-primary-sm;
  transition: all $transition-fast;
  min-height: 120rpx;
  justify-content: center;

  &:active {
    transform: scale(0.94);
    box-shadow: $shadow-primary-xs;
    background: linear-gradient(135deg, rgba($primary-color, 0.08) 0%, rgba($primary-light, 0.08) 100%);
  }
}

.grid-icon {
  font-size: 52rpx;
}

.grid-name {
  font-size: $font-size-md;
  font-weight: $font-weight-semibold;
  color: $text-primary;
}

.grid-desc {
  font-size: $font-size-xs;
  color: $text-muted;
}

/* ========== Card 样式 ========== */
.card {
  background: $bg-primary;
  border-radius: $radius-lg;
  padding: $padding-lg $padding-md;
  display: flex;
  align-items: center;
  gap: $gap-md;
  box-shadow: $shadow-md;
  transition: all $transition-fast;
  min-height: 80rpx;

  &:active {
    transform: scale(0.97);
    box-shadow: $shadow-sm;
  }

  &.featured {
    background: $primary-gradient;
    box-shadow: $shadow-primary-lg;

    .card-name,
    .card-desc {
      color: $text-white;
    }

    .card-arrow {
      color: rgba($text-white, 0.8);
    }

    &:active {
      box-shadow: $shadow-primary-md;
    }
  }
}

.card-icon {
  font-size: 56rpx;
  flex-shrink: 0;
}

.card-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.card-name {
  font-size: $font-size-md;
  font-weight: $font-weight-semibold;
  color: $text-primary;
}

.card-desc {
  font-size: $font-size-xs;
  color: $text-muted;
}

.card-arrow {
  font-size: 40rpx;
  color: $text-placeholder;
}

/* ========== 底部鼓励语 ========== */
.footer {
  margin: $margin-xl $page-padding $margin-md;
  padding: $padding-lg;
  background: linear-gradient(135deg, rgba($primary-color, 0.08) 0%, rgba($primary-light, 0.08) 100%);
  border-radius: $radius-lg;
  text-align: center;
}

.quote {
  display: block;
  font-size: $font-size-sm;
  color: $primary-color;
  line-height: $line-height-relaxed;
  font-style: italic;
}
