<!--
  哄睡故事页面
  @description 温暖故事伴你入眠
-->

<view class="container">

  <!-- 头部 -->
  <view class="header">
    <text class="title">🌙 哄睡故事</text>
    <text class="subtitle">让温暖的故事伴你入眠</text>
  </view>

  <!-- 故事列表 -->
  <view class="story-list">
    <block wx:for="{{stories}}" wx:key="id">
      <view class="story-item" bindtap="playStory" data-id="{{item.id}}">
        <view class="story-icon">{{item.icon}}</view>
        <view class="story-info">
          <text class="story-title">{{item.title}}</text>
          <text class="story-desc">{{item.description}}</text>
          <view class="story-meta">
            <text class="story-duration">⏱️ {{item.duration}}分钟</text>
            <text class="story-playcount">👂 {{item.playCount}}次</text>
          </view>
        </view>
        <view class="story-play">
          <text class="play-icon">▶️</text>
        </view>
      </view>
    </block>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{stories.length === 0}}">
    <text class="empty-icon">📖</text>
    <text class="empty-text">暂无故事</text>
  </view>

</view>
