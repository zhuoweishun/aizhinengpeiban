<!--
  放松助眠页面
  @description 放松减压、助眠功能入口
-->

<view class="container">

  <!-- 头部 -->
  <view class="header">
    <text class="title">🌙 放松助眠</text>
    <text class="subtitle">让身心放松，迎接美好明天</text>
  </view>

  <!-- 功能列表 -->
  <view class="function-list">

    <!-- 深呼吸练习 -->
    <view class="function-card" bindtap="goToBreath">
      <view class="card-icon">🧘</view>
      <view class="card-content">
        <text class="card-name">深呼吸练习</text>
        <text class="card-desc">4-7-8 呼吸法，快速放松</text>
      </view>
      <text class="card-arrow">→</text>
    </view>

    <!-- 身体扫描 -->
    <view class="function-card" bindtap="goToBodyScan">
      <view class="card-icon">💆</view>
      <view class="card-content">
        <text class="card-name">身体扫描</text>
        <text class="card-desc">渐进式肌肉放松</text>
      </view>
      <text class="card-arrow">→</text>
    </view>

    <!-- 想象疗法 -->
    <view class="function-card" bindtap="goToImagination">
      <view class="card-icon">🌸</view>
      <view class="card-content">
        <text class="card-name">想象疗法</text>
        <text class="card-desc">心灵治愈之旅</text>
      </view>
      <text class="card-arrow">→</text>
    </view>

    <!-- 快速放松 -->
    <view class="function-card" bindtap="goToQuickRelax">
      <view class="card-icon">⚡</view>
      <view class="card-content">
        <text class="card-name">快速放松</text>
        <text class="card-desc">5 分钟快速减压</text>
      </view>
      <text class="card-arrow">→</text>
    </view>

    <!-- 哄睡故事 -->
    <view class="function-card" bindtap="goToStories">
      <view class="card-icon">📖</view>
      <view class="card-content">
        <text class="card-name">哄睡故事</text>
        <text class="card-desc">温暖故事伴你入眠</text>
      </view>
      <text class="card-arrow">→</text>
    </view>

    <!-- 白噪音 -->
    <view class="function-card" bindtap="goToWhiteNoise">
      <view class="card-icon">🎵</view>
      <view class="card-content">
        <text class="card-name">白噪音</text>
        <text class="card-desc">自然声音助眠</text>
      </view>
      <text class="card-arrow">→</text>
    </view>

  </view>

</view>
