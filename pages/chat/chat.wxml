<!--
  聊天页面
  @description AI 陪伴聊天
-->

<view class="container">

  <!-- 聊天头部 -->
  <view class="chat-header">
    <view class="ai-info">
      <view class="ai-avatar">🤖</view>
      <view class="ai-detail">
        <text class="ai-name">{{aiName}}</text>
        <text class="ai-status">在线陪伴中</text>
      </view>
    </view>
    <view class="header-actions">
      <view class="action-btn" bindtap="clearChatHistory">
        <text class="action-icon">🗑️</text>
      </view>
    </view>
  </view>

  <!-- 消息列表 -->
  <scroll-view
    class="message-list"
    scroll-y
    scroll-into-view="{{scrollToView}}"
    scroll-with-animation
    enhanced
    refresher-enabled
    bindrefresherrefresh="onRefresh"
  >
    <view id="anchor"></view>

    <!-- 欢迎消息 (仅在无历史记录时显示) -->
    <view class="message-item bot-message" wx:if="{{messages.length === 0}}">
      <view class="message-avatar">🤖</view>
      <view class="message-content">
        <text class="message-text">你好呀～我是{{aiName}}，你的专属闺蜜小助手 💕 有什么想和我聊的吗？</text>
        <text class="message-time">{{currentTime}}</text>
      </view>
    </view>

    <!-- 消息列表 -->
    <block wx:for="{{messages}}" wx:key="id">
      <!-- 用户消息 -->
      <view class="message-item user-message" wx:if="{{item.type === 'user'}}" id="msg-{{item.id}}">
        <view class="message-content">
          <text class="message-text">{{item.content}}</text>
          <text class="message-time">{{item.time}}</text>
        </view>
        <view class="message-avatar">👤</view>
      </view>

      <!-- AI 消息 -->
      <view class="message-item bot-message" wx:else id="msg-{{item.id}}">
        <view class="message-avatar">🤖</view>
        <view class="message-content">
          <text class="message-text">{{item.content}}</text>
          <text class="message-time">{{item.time}}</text>
        </view>
      </view>

      <!-- 错误消息 -->
      <view class="message-item error-message" wx:if="{{item.type === 'error'}}" id="msg-{{item.id}}">
        <view class="message-avatar">🥺</view>
        <view class="message-content error-content">
          <text class="message-text error-text">{{item.content}}</text>
          <view class="error-actions" wx:if="{{item.canRetry}}">
            <text class="retry-btn" bindtap="retryLastMessage">再试一次</text>
          </view>
          <text class="message-time">{{item.time}}</text>
        </view>
      </view>
    </block>

    <!-- 加载中 -->
    <view class="loading-message" wx:if="{{loading}}">
      <view class="loading-dots">
        <text class="dot">.</text>
        <text class="dot">.</text>
        <text class="dot">.</text>
      </view>
    </view>
  </scroll-view>

  <!-- 快捷心情 (仅在刚开始聊天时显示) -->
  <view class="quick-moods" wx:if="{{messages.length <= 1}}">
    <view class="mood-item" bindtap="selectMood" data-mood="happy">😊 开心</view>
    <view class="mood-item" bindtap="selectMood" data-mood="sad">😢 难过</view>
    <view class="mood-item" bindtap="selectMood" data-mood="tired">😫 疲惫</view>
    <view class="mood-item" bindtap="selectMood" data-mood="chat">💬 聊天</view>
  </view>

  <!-- 输入区域 -->
  <view class="input-bar">
    <view class="input-wrapper">
      <input
        class="message-input"
        type="text"
        placeholder="和{{aiName}}说点什么吧~"
        placeholder-class="input-placeholder"
        value="{{inputValue}}"
        bindinput="onInputChange"
        bindconfirm="sendMessage"
        confirm-type="send"
      />
      <view class="action-buttons">
        <view class="action-btn" bindtap="showEmojiPicker">
          <text class="btn-icon">😊</text>
        </view>
        <view class="send-btn" bindtap="sendMessage" wx:if="{{inputValue.trim()}}">
          <text class="send-icon">➤</text>
        </view>
      </view>
    </view>
  </view>

</view>
