<!--
  今日小确幸页面
  @description 记录今天的小美好
-->

<view class="container">

  <view class="header">
    <text class="title">📊 今日小确幸</text>
    <text class="subtitle">记录生活中的美好瞬间</text>
  </view>

  <view class="form-section">
    <view class="form-item">
      <text class="form-label">今天发生了什么好事？</text>
      <textarea
        class="form-textarea"
        placeholder="分享一下今天的小确幸吧~"
        maxlength="500"
        value="{{content}}"
        bindinput="onContentInput"
      />
    </view>

    <view class="form-item">
      <text class="form-label">选择心情</text>
      <view class="mood-grid">
        <view
          class="mood-item {{selectedMood === index ? 'active' : ''}}"
          wx:for="{{moods}}"
          wx:key="value"
          bindtap="selectMood"
          data-index="{{index}}"
        >
          <text class="mood-icon">{{item.emoji}}</text>
          <text class="mood-label">{{item.label}}</text>
        </view>
      </view>
    </view>

    <button class="submit-btn" bindtap="submitHappiness">
      记录美好瞬间
    </button>
  </view>

  <!-- 历史记录 -->
  <view class="history-section" wx:if="{{history.length > 0}}">
    <text class="section-title">📝 历史记录</text>

    <view class="history-list">
      <block wx:for="{{history}}" wx:key="id">
        <view class="history-item">
          <text class="history-mood">{{item.moodEmoji}}</text>
          <view class="history-content">
            <text class="history-text">{{item.content}}</text>
            <text class="history-time">{{item.createdAt}}</text>
          </view>
        </view>
      </block>
    </view>
  </view>

</view>
