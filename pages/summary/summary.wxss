/**
 * 今日小确幸页面样式
 * @description 统一 UI 规范
 */

@import '../../styles/variables/_index.scss';

.container {
  min-height: 100vh;
  background: $gradient-mood;
  padding-bottom: 40rpx;
}

.header {
  text-align: center;
  padding: $padding-xl $page-padding $padding-md;
}

.title {
  display: block;
  font-size: $font-size-xxl;
  font-weight: $font-weight-bold;
  color: $mood-text-primary;
  margin-bottom: $margin-sm;
}

.subtitle {
  display: block;
  font-size: $font-size-sm;
  color: $mood-text-secondary;
}

.form-section {
  background: $bg-primary;
  margin: $margin-lg $page-margin;
  border-radius: $radius-xxl;
  padding: $padding-xl;
  box-shadow: $shadow-md;
}

.form-item {
  margin-bottom: $margin-lg;
}

.form-label {
  display: block;
  font-size: $font-size-md;
  font-weight: $font-weight-semibold;
  color: $text-primary;
  margin-bottom: $gap-sm;
}

.form-textarea {
  width: 100%;
  padding: $padding-sm;
  background: $bg-secondary;
  border-radius: $radius-md;
  font-size: $font-size-md;
  min-height: 200rpx;
}

.mood-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: $gap-sm;
}

.mood-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: $padding-sm;
  background: $bg-secondary;
  border-radius: $radius-md;
  transition: all $transition-fast;

  &.active {
    background: $blue-gradient-transparent;
    border: 2rpx solid $blue-transparent-30;
  }
}

.mood-icon {
  font-size: 40rpx;
}

.mood-label {
  font-size: $font-size-xs;
  color: $text-primary;
}

.submit-btn {
  width: 100%;
  background: $mood-gradient-btn;
  color: $text-white;
  font-size: $font-size-lg;
  padding: $padding-md;
  border-radius: $radius-lg;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(33, 150, 243, 0.3);  // 蓝色系按钮阴影，符合心情主题

  &::after {
    border: none;
  }
}

.history-section {
  margin: 0 $page-margin $margin-lg;
}

.section-title {
  display: block;
  font-size: $font-size-lg;
  font-weight: $font-weight-bold;
  color: $text-primary;
  margin-bottom: $margin-md;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: $gap-sm;
}

.history-item {
  display: flex;
  align-items: flex-start;
  gap: $gap-md;
  background: $bg-primary;
  padding: $padding-sm;
  border-radius: $radius-md;
  box-shadow: $shadow-sm;
}

.history-mood {
  font-size: 40rpx;
}

.history-content {
  flex: 1;
}

.history-text {
  display: block;
  font-size: $font-size-sm;
  color: $text-primary;
  line-height: $line-height-normal;
}

.history-time {
  display: block;
  font-size: $font-size-xs;
  color: $text-muted;
  margin-top: 8rpx;
}
