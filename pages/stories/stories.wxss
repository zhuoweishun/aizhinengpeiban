/**
 * 哄睡故事页面样式
 * @description 统一 UI 规范
 */

@import '../../styles/variables/_index.scss';

.container {
  min-height: 100vh;
  background: $gradient-stories;
  padding-bottom: 40rpx;
}

.header {
  text-align: center;
  padding: $padding-xl $page-padding $padding-md;
}

.title {
  display: block;
  font-size: $font-size-xxl;
  font-weight: $font-weight-bold;
  color: $stories-text-primary;
  margin-bottom: $margin-sm;
}

.subtitle {
  display: block;
  font-size: $font-size-sm;
  color: $stories-text-secondary;
}

.story-list {
  padding: 0 $page-padding;
  display: flex;
  flex-direction: column;
  gap: $gap-md;
}

.story-item {
  display: flex;
  align-items: center;
  gap: $gap-md;
  background: $bg-primary;
  border-radius: $radius-lg;
  padding: $padding-lg;
  box-shadow: $shadow-md;
  transition: all $transition-fast;

  &:active {
    transform: scale(0.98);
    background: $purple-gradient-transparent;
  }
}

.story-icon {
  font-size: 56rpx;
  flex-shrink: 0;
}

.story-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.story-title {
  font-size: $font-size-md;
  font-weight: $font-weight-semibold;
  color: $text-primary;
}

.story-desc {
  font-size: $font-size-xs;
  color: $text-muted;
}

.story-meta {
  display: flex;
  gap: $gap-md;
  margin-top: 4rpx;
}

.story-duration,
.story-playcount {
  font-size: $font-size-xs;
  color: $text-muted;
}

.story-play {
  flex-shrink: 0;
}

.play-icon {
  font-size: 48rpx;
  color: $primary-color;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx $page-padding;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: $margin-md;
}

.empty-text {
  font-size: $font-size-md;
  color: $text-muted;
}
