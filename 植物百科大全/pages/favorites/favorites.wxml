<!-- 收藏页面 -->
<view class="container">
  <!-- 顶部标题 -->
  <view class="header">
    <text class="title">我的收藏</text>
    <text class="count">{{favorites.length}} 个植物</text>
  </view>

  <!-- 收藏列表 -->
  <view class="favorite-list" wx:if="{{favorites.length > 0}}">
    <view 
      class="favorite-item" 
      wx:for="{{favorites}}" 
      wx:key="id"
      bindtap="goToDetail"
      data-plant="{{item}}"
    >
      <image class="plant-image" src="{{item.image}}" mode="aspectFill"></image>
      <view class="plant-info">
        <text class="plant-name">{{item.name}}</text>
        <text class="plant-family">{{item.family}}</text>
        <text class="add-time">收藏于 {{item.addTimeStr}}</text>
      </view>
      <view class="actions">
        <text class="remove-btn" catchtap="removeFavorite" data-id="{{item.id}}">移除</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    <image class="empty-icon" src="/image/empty-favorite.png" mode="aspectFit"></image>
    <text class="empty-text">还没有收藏任何植物</text>
    <text class="empty-hint">识别植物后点击收藏按钮添加</text>
    <button class="btn-primary" bindtap="goToHome">去识别</button>
  </view>
</view>