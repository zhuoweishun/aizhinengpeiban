<!--
  瓜瓜陪伴微信小程序 - 首页
  @description 主菜单页面，场景化入口
-->

<view class="container">

  <!-- 顶部状态栏 -->
  <view class="status-bar">
    <view class="date-time">
      <text class="date">{{currentDate}}</text>
      <text class="time">{{currentTime}}</text>
    </view>
    <view class="user-info">
      <text class="level">Lv.{{userLevel}}</text>
    </view>
  </view>

  <!-- 标题区域 -->
  <view class="header">
    <text class="main-title">💕 {{aiName}}陪伴</text>
    <text class="sub-title">你的专属闺蜜小助手</text>
  </view>

  <!-- 树洞互动区域 -->
  <view class="tree-hole-section">
    <view class="tree-hole-image" bindtap="hugTreeHole">
      <image
        class="tree-hole-illustration"
        src="/images/treehole/main.png"
        mode="aspectFit"
      />
    </view>

    <view class="interaction-buttons">
      <view class="interaction-btn" bindtap="hugTreeHole">
        <text class="btn-icon">🤗</text>
        <text class="btn-text">抱抱</text>
      </view>
      <view class="interaction-btn" bindtap="quickChat">
        <text class="btn-icon">💬</text>
        <text class="btn-text">聊天</text>
      </view>
      <view class="interaction-btn" bindtap="recordMood">
        <text class="btn-icon">😊</text>
        <text class="btn-text">心情</text>
      </view>
    </view>
  </view>

  <!-- 商业化功能 -->
  <view class="section">
    <view class="section-title">
      <text class="title">🎁 福利中心</text>
      <text class="hint">做任务 · 攒积分 · 兑好礼</text>
    </view>

    <view class="grid-menu">
      <view class="grid-item" bindtap="goToPointsShop">
        <text class="grid-icon">🌟</text>
        <text class="grid-name">积分商城</text>
        <text class="grid-desc">兑水晶折扣券</text>
      </view>
      <view class="grid-item" bindtap="goToTasks">
        <text class="grid-icon">📋</text>
        <text class="grid-name">每日任务</text>
        <text class="grid-desc">完成任务赚星光</text>
      </view>
      <view class="grid-item" bindtap="goToCoupons">
        <text class="grid-icon">🎫</text>
        <text class="grid-name">优惠券</text>
        <text class="grid-desc">水晶折扣券</text>
      </view>
      <view class="grid-item" bindtap="goToMyPoints">
        <text class="grid-icon">💎</text>
        <text class="grid-name">我的积分</text>
        <text class="grid-desc">星光值晶钻</text>
      </view>
    </view>
  </view>

  <!-- 宿舍装修 -->
  <view class="section">
    <view class="section-title">
      <text class="title">🎨 宿舍装修</text>
      <text class="hint">装扮你的温馨小窝</text>
    </view>

    <view class="card" bindtap="goToDecorationShop">
      <text class="card-icon">🏡✨</text>
      <view class="card-content">
        <text class="card-name">装修商城</text>
        <text class="card-desc">家具、壁纸、装饰品</text>
      </view>
      <text class="card-arrow">→</text>
    </view>
  </view>

  <!-- 女生宿舍 -->
  <view class="section">
    <view class="section-title">
      <text class="title">🏠 女生宿舍</text>
      <text class="hint">{{hasDormitory ? '和闺蜜的小天地' : '创建你的宿舍'}}</text>
    </view>

    <view class="card" bindtap="goToDormitory">
      <text class="card-icon">🏠💖</text>
      <view class="card-content">
        <text class="card-name">女生宿舍</text>
        <text class="card-desc">{{hasDormitory ? '查看宿舍动态' : '创建专属宿舍'}}</text>
      </view>
      <text class="card-arrow">→</text>
    </view>
  </view>

  <!-- 常用功能 -->
  <view class="section">
    <view class="section-title">
      <text class="title">✨ 常用功能</text>
      <text class="hint">记录心情、放松助眠</text>
    </view>

    <view class="grid-menu">
      <view class="grid-item" bindtap="goToSummary">
        <text class="grid-icon">📊</text>
        <text class="grid-name">小确幸</text>
        <text class="grid-desc">记录美好</text>
      </view>
      <view class="grid-item" bindtap="goToMoodStats">
        <text class="grid-icon">💗</text>
        <text class="grid-name">心情日记</text>
        <text class="grid-desc">情绪变化</text>
      </view>
      <view class="grid-item" bindtap="goToStories">
        <text class="grid-icon">🌙</text>
        <text class="grid-name">哄睡故事</text>
        <text class="grid-desc">伴你入眠</text>
      </view>
      <view class="grid-item" bindtap="goToRelax">
        <text class="grid-icon">🧘</text>
        <text class="grid-name">放松</text>
        <text class="grid-desc">减压助眠</text>
      </view>
    </view>
  </view>

  <!-- 陪伴聊天 -->
  <view class="section">
    <view class="section-title">
      <text class="title">💬 陪伴聊天</text>
    </view>

    <view class="card featured" bindtap="quickChat">
      <text class="card-icon">💕</text>
      <view class="card-content">
        <text class="card-name">说说心里话</text>
        <text class="card-desc">和{{aiName}}聊聊你的小秘密~</text>
      </view>
      <text class="card-arrow">→</text>
    </view>
  </view>

  <!-- 个人中心 -->
  <view class="section">
    <view class="card" bindtap="goToProfile">
      <text class="card-icon">👤</text>
      <view class="card-content">
        <text class="card-name">我的小天地</text>
        <text class="card-desc">个人设置、成就、统计</text>
      </view>
      <text class="card-arrow">→</text>
    </view>
  </view>

  <!-- 底部鼓励语 -->
  <view class="footer">
    <text class="quote">{{dailyQuote}}</text>
  </view>

</view>
